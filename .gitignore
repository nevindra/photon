/target
**/*.rs.bk
Cargo.lock.orig
# subagent-driven-development process scratch (ledger, reports, review packages)
/.superpowers/
# frontend build artifacts (dist is regenerated by `npm run build` before embedding)
/frontend/node_modules
/frontend/dist
# local dev stack (`make dev`): generated config + data dir, both throwaway
/photon.dev.toml
/.photon-dev/
# uptime monitor's local SQLite store (photon.example.toml's default db_path); runtime data
/data/
.superpowers/

# throwaway write-path benchmark data dirs (scripts/bench-ingest.sh, wal append bench)
.photon-bench*

# docker deployment: local env file holds secrets — never commit it (the example IS tracked)
.env
.env.*
!.env.example
# config env-only smoke-test scratch dir (Config::load local run)
/.photon-smoke/
