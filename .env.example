# Copy to `.env` and fill in. `docker compose` reads `.env` automatically.

# --- Required -------------------------------------------------------------------------------
# OTLP ingest bearer token (treat like a password). Generate: openssl rand -hex 32
PHOTON_INGEST_TOKEN=change-me-ingest-token
# Session cookie signing secret, >= 32 bytes. Generate: openssl rand -hex 32
PHOTON_SESSION_SECRET=change-me-session-secret-at-least-32-bytes

# --- Optional tuning (defaults shown) -------------------------------------------------------
# PHOTON_RETENTION_DAYS=30
# PHOTON_PROMOTED_ATTRIBUTES=service.name,host.name
# PHOTON_INGEST_MAX_IN_FLIGHT=256

# --- Durable S3 tier (only used with `--profile durable`; see deploy/README.md) -------------
# Uncommenting these enables hot->durable replication to the bundled Garage. The key id/secret
# below are the compose defaults and MUST stay valid Garage formats (id = "GK" + 24 hex chars;
# secret = 64 hex chars) or `garage key import` rejects them. Regenerate for production:
#   id:     printf 'GK%s' "$(openssl rand -hex 12)"
#   secret: openssl rand -hex 32
# PHOTON_DURABLE_ENDPOINT=http://garage:3900
# PHOTON_DURABLE_BUCKET=photon
# PHOTON_DURABLE_REGION=garage
# PHOTON_DURABLE_ACCESS_KEY_ID=GK43ba46c38ae6886c283896c1
# PHOTON_DURABLE_SECRET_ACCESS_KEY=1efa8a1bf2156fa1e93ddc088339993ddf56501970e82e87a0282716237f1d62
